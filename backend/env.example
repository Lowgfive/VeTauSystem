# VéTàu System - Environment Config
# Copy file này thành .env và điền giá trị thực

# App
PORT=4000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/vetau

# JWT
JWT_SECRET=change_me_to_a_strong_secret
JWT_EXPIRES_IN=7d

# Frontend URL (Socket.io CORS)
CLIENT_URL=http://localhost:5173

# Email (Nodemailer / Gmail SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=yourmail@gmail.com
MAIL_PASS=your_app_password

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

